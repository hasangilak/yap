PORT=3001
OLLAMA_HOST=http://localhost:11434
MODEL=qwen2.5:14b

# Postgres connection string used by the Prisma client and `prisma db push`.
# In docker-compose this is overridden per-service to postgres://yap:yap@postgres:5432/yap
DATABASE_URL=postgres://yap:yap@localhost:5432/yap

# The chrome-less browser CLI is installed as an npm dependency, so no
# path is needed by default. Set CHROME_LESS_BIN only to point at a
# different local build.
# CHROME_LESS_BIN=/absolute/path/to/chrome-less/dist/cli.js

# Safety cap for the tool-calling loop — how many browser rounds the model
# may take in a single run before the server forces a stop.
MAX_TOOL_ROUNDS=8

