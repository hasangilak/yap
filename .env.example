PORT=3001
OLLAMA_HOST=http://localhost:11434
MODEL=qwen2.5:14b

# Path to the chrome-less compiled CLI. Defaults to ../chrome-lite/dist/cli.js
# relative to the repo root, so cloning chrome-lite next to yap works out of
# the box.
# CHROME_LESS_BIN=/absolute/path/to/chrome-lite/dist/cli.js

# Safety cap for the tool-calling loop — how many browser rounds the model
# may take in a single run before the server forces a stop.
MAX_TOOL_ROUNDS=8

