PORT=3001
OLLAMA_HOST=http://localhost:11434
MODEL=qwen2.5:14b

# Postgres connection string used by the Prisma client and `prisma db push`.
# In docker-compose this is overridden per-service to postgres://yap:yap@postgres:5432/yap
DATABASE_URL=postgres://yap:yap@localhost:5432/yap

# The chrome-less browser CLI is installed as an npm dependency, so no
# path is needed by default. Set CHROME_LESS_BIN only to point at a
# different local build.
# CHROME_LESS_BIN=/absolute/path/to/chrome-less/dist/cli.js

# Safety cap for the tool-calling loop — how many browser rounds the model
# may take in a single run before the server forces a stop.
MAX_TOOL_ROUNDS=8

# Sandbox directory for the write_file tool. Paths outside this dir are
# rejected by the runtime regardless of what the model sends. Defaults
# to ../artifacts relative to the repo.
# ARTIFACTS_DIR=/absolute/path/to/artifacts

# Phase 8: optional bearer token guarding /api/v1/*. Unset = open mode
# (existing dev behavior). Set to any string to require
# Authorization: Bearer <token> on every /api/v1 request except
# /api/v1/shared/:token which is public by design.
# YAP_API_TOKEN=dev-secret

# Phase 8: per-tool-call deadline in ms (AbortController). Ollama's
# stream is cancelled if a single tool round exceeds this budget.
TOOL_DEADLINE_MS=30000

# Phase 8: sliding-window rate limit in requests per minute, per
# bearer token (or per IP in open mode).
RATE_LIMIT_RPM=60

