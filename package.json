{
  "name": "simplest-llm",
  "private": true,
  "version": "0.0.1",
  "description": "AG-UI compatible server that bridges Ollama to the Agent-User Interaction Protocol.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push --accept-data-loss",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@ag-ui/core": "^0.0.52",
    "@ag-ui/encoder": "^0.0.52",
    "@hono/node-server": "^1.19.14",
    "@prisma/client": "6",
    "chrome-less": "github:hasangilak/chrome-cli",
    "diff": "^9.0.0",
    "hono": "^4.12.14",
    "ollama": "^0.6.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^22.10.0",
    "prisma": "6",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
