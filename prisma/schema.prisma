generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Chat-box conversation. The wire shape exposed at /api/v1/conversations
/// has a display-name `agent` field and a display-string `updated` field;
/// those are computed from `agentId` (via Agent.name) and `updatedAt`.
model Conversation {
  id             String   @id
  title          String
  snippet        String   @default("")
  agentId        String   @map("agent_id")
  tag            String?
  pinned         Boolean  @default(false)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at")
  rootNodeId     String?  @map("root_node_id")
  activeLeafId   String?  @map("active_leaf_id")
  tokenBudget    Int      @default(200000) @map("token_budget")
  tokensUsed     Int      @default(0)      @map("tokens_used")

  nodes  Node[]
  events Event[]

  @@index([pinned(sort: Desc), updatedAt(sort: Desc)])
  @@map("conversations")
}

/// One message in the conversation tree. The wire shape omits several
/// server-internal fields (parent_id → parent, edited_from_id absent).
/// `role` is strictly 'user' | 'asst' — client does not accept
/// 'assistant'.
model Node {
  id             String   @id
  conversationId String   @map("conversation_id")
  parentId       String?  @map("parent_id")
  role           String
  branch         String   @default("main")
  content        String   @default("")
  reasoning      Json?
  toolCall       Json?    @map("tool_call")
  clarify        Json?
  approval       Json?
  streaming      Boolean  @default(false)
  status         String?
  edited         Boolean  @default(false)
  editedFromId   String?  @map("edited_from_id")
  createdAt      DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, branch, createdAt])
  @@map("nodes")
}

/// Wire Agent is { id, name, initial, desc, model, tools: number, temp }.
/// `tools` on the wire is a COUNT derived from toolIds length; the model
/// keeps the full array. Builder-form fields (systemPrompt etc.) are
/// surfaced via GET /agents/:id/full and editable via PATCH.
model Agent {
  id                String  @id
  name              String
  initial           String
  description       String  @default("")
  model             String
  temperature       Float   @default(0.5)
  topP              Float   @default(1.0) @map("top_p")
  maxTokens         Int     @default(4096) @map("max_tokens")
  systemPrompt      String  @default("") @map("system_prompt")
  toolIds           Json    @default("[]") @map("tool_ids")
  variables         Json    @default("[]")
  /// Phase 2: one of 'ask_every_time' | 'auto_allow_read' | 'auto_allow_all'.
  /// Drives whether a tool call needs an approval round-trip.
  permissionDefault String  @default("ask_every_time") @map("permission_default")
  /// Phase 4: id of the AgentVersion that represents the current saved
  /// state. Updated on every PATCH that writes a new version.
  currentVersionId  String? @map("current_version_id")
  /// Phase 4: soft-delete marker. Rows with a non-null deletedAt are
  /// hidden from listings but kept around so version history survives.
  deletedAt         DateTime? @map("deleted_at")

  versions          AgentVersion[]

  @@map("agents")
}

/// Phase 4: every PATCH /agents/:id that changes agent state writes
/// one of these. snapshot is the full materialized Agent at save time;
/// version is a monotonic per-agent integer starting at 1.
model AgentVersion {
  id              String   @id
  agentId         String   @map("agent_id")
  version         Int
  message         String   @default("")
  snapshot        Json
  evalScore       Float?   @map("eval_score")
  parentVersionId String?  @map("parent_version_id")
  createdAt       DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([agentId, version])
  @@index([agentId])
  @@map("agent_versions")
}

/// Phase 2: one row per proposed tool call that needs user approval.
/// The conversation is paused until `decision` is set; the runtime
/// awaits a POST /approvals/:id/decide call that fills this in and
/// resolves the pending promise.
model Approval {
  id             String    @id
  conversationId String    @map("conversation_id")
  nodeId         String    @map("node_id")
  tool           String
  title          String
  body           String
  preview        String?
  decision       String?
  decidedAt      DateTime? @map("decided_at")
  /// When decision='always', this is the key stored in ApprovalGrant so
  /// future calls skip approval entirely.
  rememberKey    String?   @map("remember_key")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([conversationId])
  @@map("approvals")
}

/// Phase 2: persistent "allow always" grants keyed by (user, agent, tool).
/// userId is hardcoded 'local' until the multi-user phase lands.
model ApprovalGrant {
  userId    String   @map("user_id")
  agentId   String   @map("agent_id")
  toolId    String   @map("tool_id")
  createdAt DateTime @default(now()) @map("created_at")

  @@id([userId, agentId, toolId])
  @@map("approval_grants")
}

/// Every BusEvent persisted before publication, so the SSE stream can
/// be resumed with ?since_event=<id>.
model Event {
  seq             BigInt   @id @default(autoincrement())
  id              String   @unique
  conversationId  String   @map("conversation_id")
  nodeId          String?  @map("node_id")
  kind            String
  payload         Json
  at              DateTime

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, seq])
  @@map("events")
}
